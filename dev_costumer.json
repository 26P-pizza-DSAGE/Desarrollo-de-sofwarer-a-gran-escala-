{
  "name": "Flutter Dev Container",
  "image": "ghcr.io/cirruslabs/flutter:stable",
  "features": {},
  "postCreateCommand": "/bin/sh -c 'flutter pub get'",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true
      },
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ]
    }
  }
}